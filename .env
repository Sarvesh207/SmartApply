# Database connection URL (maps to the docker-compose PostgreSQL container when running locally)
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/smartapply?schema=public"

# Redis queue settings
REDIS_HOST="localhost"
REDIS_PORT=6379

# API configuration
PORT=5000
JWT_SECRET="smartapply-secret-key-12345"
CORS_ORIGIN="*"
